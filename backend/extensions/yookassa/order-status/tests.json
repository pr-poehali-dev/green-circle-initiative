{
  "tests": [
    {
      "name": "Get order status - missing order_number",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {
        "error": "order_number is required"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Get order status - not found",
      "method": "GET",
      "path": "/?order_number=NONEXISTENT",
      "expectedStatus": 404,
      "expectedBody": {
        "error": "Order not found"
      },
      "bodyMatcher": "partial"
    }
  ]
}
