{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {
        "email": "test@example.com",
        "password": "Test1234",
        "name": "Test User"
      },
      "expectedStatus": 201,
      "expectedBody": {
        "user_id": "number",
        "message": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "email": "admin@example.com",
        "password": "admin"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "access_token": "string",
        "token_type": "Bearer",
        "expires_in": 900,
        "user": {
          "id": "number",
          "email": "string"
        }
      },
      "bodyMatcher": "partial"
    }
  ]
}
