{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/register",
      "body": {
        "email": "test@example.com",
        "password": "TestPass123",
        "name": "Test User"
      },
      "expectedStatus": 201,
      "expectedBody": {
        "user_id": "number",
        "message": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with valid credentials",
      "method": "POST",
      "path": "/login",
      "body": {
        "email": "test@example.com",
        "password": "TestPass123"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "access_token": "string",
        "expires_in": 900,
        "user": {
          "email": "test@example.com"
        }
      },
      "bodyMatcher": "partial"
    }
  ]
}
