{
  "tests": [
    {
      "name": "Test default greeting with full data",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {
        "status": "success",
        "mission": "Твой путь к звездам начинается здесь!"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Test custom name with full mode",
      "method": "GET",
      "path": "/?name=Yura&mode=full",
      "expectedStatus": 200,
      "expectedBody": {
        "status": "success",
        "planetOfTheDay": {}
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Test quick mode",
      "method": "GET",
      "path": "/?mode=quick",
      "expectedStatus": 200,
      "expectedBody": {
        "status": "success"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Test POST mission action",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "mission",
        "name": "Юра"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "status": "success",
        "action": "mission"
      },
      "bodyMatcher": "partial"
    }
  ]
}
